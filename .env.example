# Copia a .env y ajusta valores
# En Windows: copy .env.example .env

# Usuario que ejecuta Airflow en los contenedores (evita permisos en dags/logs)
# Linux/Mac: AIRFLOW_UID=$(id -u)  |  Windows: dejar 50000
AIRFLOW_UID=50000

# Ruta al JSON de cuenta de servicio GCP (dentro del contenedor)
# Por defecto se usa ./gcp-credentials/key.json montado en /opt/airflow/gcp-credentials/key.json
# Opcional: si usas otro nombre de fichero, descomenta y apunta al path dentro del contenedor:
# GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/gcp-credentials/mi-cuenta.json

# Usuario y contraseña del UI de Airflow (solo desarrollo)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Directorio base del proyecto (por defecto .)
# AIRFLOW_PROJ_DIR=.

# BigQuery (pipeline transaccional y KPI recurrencia 30d)
# Crear el dataset en BigQuery antes de la primera carga (ej. cala_analytics)
# BQ_PROJECT_ID=tu-proyecto-gcp
# BQ_DATASET_ID=cala_analytics

# Commit automático de razonamiento.json (DAG 3, tarea commit_razonamiento_json)
# GITHUB_TOKEN=ghp_xxxx
# GITHUB_REPO=owner/repo
